# peasy-audio-rb — Audio trim, merge, convert (Ruby)
# Theme: Solarized Dark
# Generated for AgentGIF demo collection

Output demo.gif
Set Shell "zsh"
Set Theme "Builtin Solarized Dark"
Set Width 800
Set Height 500
Set FontSize 14
Set Padding 20
Set TypingSpeed 50ms

# Show package info
Type "# peasy-audio-rb — Audio trim, merge, convert for Ruby"
Enter
Type "# peasyaudio.com"
Enter
Sleep 500ms

# Run the demo
Type "ruby -I lib examples/demo.rb"
Enter
Sleep 5s
